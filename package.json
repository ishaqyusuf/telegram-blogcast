{
  "name": "nextjs-template",
  "devDependencies": {
    "@types/node": "^24.0.4",
    "check-dependency-version-consistency": "5.0.1",
    "knip": "^5.61.2",
    "portless": "^0.11.1"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.9",
  "catalog": {
    "zod": "^4.3.5"
  },
  "private": true,
  "scripts": {
    "build": "node ./node_modules/turbo/bin/turbo build",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "node ./node_modules/turbo/bin/turbo clean",
    "db:push": "node ./node_modules/turbo/bin/turbo -F @acme/db push",
    "db:migrate": "node ./node_modules/turbo/bin/turbo -F @acme/db db-migrate",
    "db:generate": "node ./node_modules/turbo/bin/turbo -F @acme/db prisma-generate",
    "db:push-reset": "node ./node_modules/turbo/bin/turbo -F @acme/db push-reset",
    "db:compact-shamela-urls": "node ./node_modules/turbo/bin/turbo -F @acme/db compact-shamela-urls",
    "facebook-saved:import": "bun scripts/facebook-saved/import-to-db.ts",
    "facebook-media-bridge:install": "cd services/facebook-media-bridge && python3 -m venv .venv && . .venv/bin/activate && pip install -r requirements.txt",
    "facebook-media-bridge:dev": "cd services/facebook-media-bridge && . .venv/bin/activate && uvicorn main:app --host 0.0.0.0 --port 8790",
    "dev": "bun run kill:ports && node ./node_modules/turbo/bin/turbo dev --parallel --filter=!@acme/api",
    "kill:ports": "node ./scripts/kill-dev-ports.mjs",
    "terminal": "bash ./scripts/open-bun-script-terminal.sh",
    "dev:terminal": "bun run terminal dev",
    "eas-build:dev": "bun ./scripts/eas-account-runner.ts eas-build:dev",
    "eas-build:preview": "bun ./scripts/eas-account-runner.ts eas-build:preview",
    "eas-update:preview": "bun ./scripts/eas-account-runner.ts update:preview",
    "format": "biome format --write .",
    "lint": "node ./node_modules/turbo/bin/turbo lint && manypkg check",
    "---format": "node ./node_modules/turbo/bin/turbo format --continue -- --cache --cache-location='node_modules/.cache/.prettiercache' --ignore-path='../../.gitignore'",
    "---format:fix": "node ./node_modules/turbo/bin/turbo format --continue -- --write --cache --cache-location='node_modules/.cache/.prettiercache' --ignore-path='../../.gitignore'",
    "---lint": "node ./node_modules/turbo/bin/turbo lint -- --quiet -- --cache --cache-location 'node_modules/.cache/.eslintcache' && manypkg check",
    "lint:fix": "node ./node_modules/turbo/bin/turbo lint --continue -- --fix --cache --cache-location 'node_modules/.cache/.eslintcache' ",
    "typecheck": "node ./node_modules/turbo/bin/turbo typecheck",
    "--postinstall": "bun run check-deps",
    "check-deps": "check-dependency-version-consistency .",
    "gen": "node ./node_modules/turbo/bin/turbo gen --config 'turbo/generators/config.ts'",
    "knip": "knip",
    "transcriber:install": "cd services/transcriber && python3 -m venv .venv && . .venv/bin/activate && pip install -r requirements.txt",
    "transcriber:dev": "cd services/transcriber && . .venv311/bin/activate && WHISPER_MODEL=${WHISPER_MODEL:-mlx-community/whisper-large-v3-turbo} PRELOAD_WHISPER=1 TRANSCRIPTION_QUEUE_API_BASE_URL=${TRANSCRIPTION_QUEUE_API_BASE_URL:-http://127.0.0.1:3501} uvicorn main:app --host 0.0.0.0 --port 8787",
    "android": "PATH=/Users/M1PRO/Library/Android/sdk/platform-tools:$PATH /Users/M1PRO/Library/Android/sdk/platform-tools/adb uninstall com.alghurobaa.podcast 2>/dev/null || true && PATH=/Users/M1PRO/Library/Android/sdk/platform-tools:$PATH bun run --cwd apps/expo-app android"
  },
  "overrides": {
    "lightningcss": "1.30.1",
    "react-dom": "19.1.0"
  },
  "patchedDependencies": {
    "react-native-track-player@4.1.2": "patches/react-native-track-player@4.1.2.patch"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "tooling/*"
  ],
  "dependencies": {
    "@biomejs/biome": "1.9.4",
    "@manypkg/cli": "^0.24.0",
    "bcrypt-ts": "^5.0.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dayjs": "^1.11.18",
    "dot-object": "^2.1.5",
    "framer-motion": "^12.23.24",
    "nanoid": "^5.1.5",
    "react-intersection-observer": "^9.16.0",
    "react-markdown": "^10.1.0",
    "react-responsive": "^10.0.1",
    "slugify": "^1.6.6",
    "superjson": "2.2.1",
    "tailwind-merge": "^3.3.1",
    "turbo": "2.5.8",
    "typescript": "^5.9.3"
  }
}
