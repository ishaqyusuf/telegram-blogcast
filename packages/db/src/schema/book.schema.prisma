model BookShelf {
  id        Int       @id @default(autoincrement())
  createdAt DateTime? @default(now()) @db.Timestamp(0)
  updatedAt DateTime? @updatedAt
  deletedAt DateTime?
  name      String    @unique
  nameAr    String?
  books     Book[]
}

model BookAuthor {
  id        Int       @id @default(autoincrement())
  createdAt DateTime? @default(now()) @db.Timestamp(0)
  updatedAt DateTime? @updatedAt
  name      String    @unique
  nameAr    String?
  url       String?
  books     Book[]

  @@index([name])
}

model Book {
  id             Int          @id @default(autoincrement())
  createdAt      DateTime?    @default(now()) @db.Timestamp(0)
  updatedAt      DateTime?    @updatedAt
  deletedAt      DateTime?
  blogId         Int          @unique
  blog           Blog         @relation(fields: [blogId], references: [id])
  nameAr         String?
  nameEn         String?
  coverUrl       String?
  coverColor     String?
  shamelaId      Int?
  shamelaUrl     String?
  category       String?
  categoryUrl    String?
  shelfId        Int?
  shelf          BookShelf?   @relation(fields: [shelfId], references: [id])
  volumes        BookVolume[]
  pages          BookPage[]
  importHistory  BookImportHistory[]
  pageImports    BookPageImportHistory[]
  rawPages       ShamelaRawPage[]
  stagedParses   ShamelaStagedPageParse[]
  authors        BookAuthor[]
  // Offline sync fields — updated whenever a page is fetched
  contentHash    String?
  pagesUpdatedAt DateTime?

  @@index([blogId])
  @@index([shelfId])
}

model BookVolume {
  id        Int        @id @default(autoincrement())
  createdAt DateTime?  @default(now()) @db.Timestamp(0)
  updatedAt DateTime?  @updatedAt
  deletedAt DateTime?
  bookId    Int
  book      Book       @relation(fields: [bookId], references: [id])
  number    Int
  title     String?
  pages     BookPage[]

  @@unique([bookId, number])
  @@index([bookId])
}

model BookPage {
  id            Int                 @id @default(autoincrement())
  createdAt     DateTime?           @default(now()) @db.Timestamp(0)
  updatedAt     DateTime?           @updatedAt
  deletedAt     DateTime?
  bookId        Int
  book          Book                @relation(fields: [bookId], references: [id])
  volumeId      Int?
  volume        BookVolume?         @relation(fields: [volumeId], references: [id])
  shamelaPageNo Int
  shamelaUrl    String
  printedPageNo Int?
  chapterTitle  String?
  chapterUrl    String?
  topicTitle    String?
  topicUrl      String?
  rawJson       Json?
  documentJson  Json?
  status        String              @default("pending")
  paragraphs    BookPageParagraph[]
  footnotes     BookPageFootnote[]
  highlights    BookPageHighlight[]
  comments      BookPageComment[]
  importHistory BookPageImportHistory[]
  stagedParses  ShamelaStagedPageParse[]

  @@unique([bookId, shamelaPageNo])
  @@index([bookId])
  @@index([volumeId])
}

model BookPageParagraph {
  id          Int                 @id @default(autoincrement())
  pageId      Int
  page        BookPage            @relation(fields: [pageId], references: [id])
  pid         Int
  text        String
  footnoteIds String?
  highlights  BookPageHighlight[]

  @@index([pageId])
}

model BookPageFootnote {
  id               Int      @id @default(autoincrement())
  pageId           Int
  page             BookPage @relation(fields: [pageId], references: [id])
  marker           String
  type             String?
  content          String
  linkedParagraphs String?
  items            Json?

  @@index([pageId])
}

model BookPageHighlight {
  id          Int                @id @default(autoincrement())
  createdAt   DateTime?          @default(now()) @db.Timestamp(0)
  updatedAt   DateTime?          @updatedAt
  pageId      Int
  page        BookPage           @relation(fields: [pageId], references: [id])
  paragraphId Int?
  paragraph   BookPageParagraph? @relation(fields: [paragraphId], references: [id])
  userId      Int
  pageShamelaPageNo Int?
  paragraphPid Int?
  startOffset Int
  endOffset   Int
  color       String             @default("#FFD700")
  note        String?
  quoteText   String?

  @@index([pageId])
  @@index([userId])
}

model BookPageComment {
  id          Int       @id @default(autoincrement())
  createdAt   DateTime? @default(now()) @db.Timestamp(0)
  updatedAt   DateTime? @updatedAt
  deletedAt   DateTime?
  pageId      Int
  page        BookPage  @relation(fields: [pageId], references: [id])
  userId      Int
  content     String
  paragraphId Int?
  pageShamelaPageNo Int?
  paragraphPid Int?
  quoteText   String?

  @@index([pageId])
  @@index([userId])
}

model BookImportHistory {
  id              Int       @id @default(autoincrement())
  createdAt       DateTime  @default(now()) @db.Timestamp(0)
  updatedAt       DateTime? @updatedAt
  bookId          Int?
  book            Book?     @relation(fields: [bookId], references: [id])
  sourceUrl       String
  normalizedUrl   String?
  provider        String?
  importMode      String    @default("link")
  status          String    @default("pending")
  errorMessage    String?
  createdBookId   Int?
  chaptersImported Int      @default(0)
  metadataJson    Json?
  startedAt       DateTime? @default(now()) @db.Timestamp(0)
  finishedAt      DateTime?

  @@index([bookId, createdAt])
  @@index([status, createdAt])
}

model BookPageImportHistory {
  id             Int       @id @default(autoincrement())
  createdAt      DateTime  @default(now()) @db.Timestamp(0)
  updatedAt      DateTime? @updatedAt
  bookId         Int
  book           Book      @relation(fields: [bookId], references: [id])
  pageId         Int?
  page           BookPage? @relation(fields: [pageId], references: [id])
  sourceUrl      String?
  provider       String?
  importMethod   String
  status         String    @default("pending")
  errorMessage   String?
  shamelaPageNo  Int?
  printedPageNo  Int?
  paragraphCount Int       @default(0)
  footnoteCount  Int       @default(0)
  chapterTitle   String?
  topicTitle     String?
  diffSummaryJson Json?
  rawInput       String?
  startedAt      DateTime? @default(now()) @db.Timestamp(0)
  finishedAt     DateTime?

  @@index([bookId, createdAt])
  @@index([pageId, createdAt])
  @@index([status, createdAt])
}

model AiTokenUsage {
  id           Int      @id @default(autoincrement())
  createdAt    DateTime @default(now()) @db.Timestamp(0)
  provider     String
  model        String
  operation    String
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  bookId       Int?
  pageId       Int?

  @@index([createdAt])
  @@index([provider])
  @@index([bookId])
}

model ShamelaRawPage {
  id            Int       @id @default(autoincrement())
  createdAt     DateTime  @default(now()) @db.Timestamp(0)
  updatedAt     DateTime? @updatedAt
  bookId        Int?
  book          Book?     @relation(fields: [bookId], references: [id])
  requestedUrl  String
  finalUrl      String
  normalizedUrl String?
  title         String?
  html          String
  htmlHash      String
  source        String    @default("mobile-webview")
  captureStatus String    @default("captured")
  shamelaPageNo Int?
  metadataJson  Json?
  stagedParses  ShamelaStagedPageParse[]

  @@index([bookId, createdAt])
  @@index([htmlHash])
  @@index([normalizedUrl])
  @@index([shamelaPageNo])
}

model ShamelaStagedPageParse {
  id              Int       @id @default(autoincrement())
  createdAt       DateTime  @default(now()) @db.Timestamp(0)
  updatedAt       DateTime? @updatedAt
  rawPageId       Int
  rawPage         ShamelaRawPage @relation(fields: [rawPageId], references: [id])
  bookId          Int?
  book            Book?     @relation(fields: [bookId], references: [id])
  promotedPageId  Int?
  promotedPage    BookPage? @relation(fields: [promotedPageId], references: [id])
  status          String    @default("parsed")
  parserVersion   String
  shamelaPageNo   Int?
  printedPageNo   Int?
  volumeNumber    Int?
  chapterTitle    String?
  chapterUrl      String?
  topicTitle      String?
  topicUrl        String?
  paragraphsJson  Json
  footnotesJson   Json
  factsJson       Json?
  documentJson    Json?
  diagnosticsJson Json?
  renderModelJson Json?
  linkGraphJson   Json?

  @@index([rawPageId, createdAt])
  @@index([bookId, createdAt])
  @@index([promotedPageId])
  @@index([status, createdAt])
}
