model Blog {
    id Int @unique @default(autoincrement())

    content     String?
    published   Boolean?  @default(false)
    publishedAt DateTime?
    status      String?
    meta        Json?
    source      String?
    sourceId    String?
    sourceUrl   String?
    sourceSyncedAt DateTime?
    telegramMessageId Int?

    blogDate DateTime?

    createdAt DateTime? @default(now()) @db.Timestamp(0)
    updatedAt DateTime? @updatedAt
    deletedAt DateTime?

    // audio     BlogAudio?     @relation(fields: [audioId], references: [id])
    type            String  @default("text")
    arrangementMode String  @default("default")
    medias          Media[]

    comments    BlogComments[] @relation(name: "comment")
    blogs       BlogComments[] @relation(name: "blog")
    channel     Channel?       @relation(fields: [channelId], references: [id])
    channelId   Int?
    thumbnailId Int?

    interactions   BlogViews[]
    blogTags       BlogTags[]
    thumbnail      Thumbnail?       @relation(fields: [thumbnailId], references: [id])
    reactions      Reaction[]
    recentlyViewed RecentlyViewed[]

    blogLocation   BlogLocation? @relation(fields: [blogLocationId], references: [id])
    blogLocationId Int?
    book           Book?

    @@unique([channelId, telegramMessageId])
    @@unique([source, sourceId])
    @@index([source, sourceSyncedAt])
}

model BlogComments {
    id        Int       @unique @default(autoincrement())
    createdAt DateTime? @default(now()) @db.Timestamp(0)
    updatedAt DateTime? @updatedAt
    deletedAt DateTime?
    blogId    Int
    commentId Int
    order     Int       @default(0)
    blog      Blog      @relation(name: "blog", fields: [blogId], references: [id])
    comment   Blog      @relation(name: "comment", fields: [commentId], references: [id])

    @@index([blogId])
}
